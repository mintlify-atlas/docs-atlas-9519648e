  "keyFeatures": [
    "100+ production-ready LLM application examples",
    "Multi-agent systems with specialized agent teams",
    "RAG implementations with multiple retrieval strategies",
    "Voice AI agents with audio processing",
    "MCP (Model Context Protocol) integrations",
    "Support for OpenAI, Anthropic, Gemini, and open-source models",
    "Framework crash courses (Google ADK, OpenAI SDK)",
    "Reusable agent skills following AgentSkills.io specification",
    "Local and cloud deployment options",
    "Memory management and optimization techniques"
  ],
  "publicApiSurface": [
    "AI Travel Agent - Personalized itinerary generation with calendar export",
    "AI Research Agent - Deep web research with citations and synthesis",
    "Finance Agent Team - Multi-agent financial analysis with YFinance integration",
    "Legal Agent Team - Document analysis and legal research coordination",
    "Agentic RAG - Autonomous retrieval with reasoning and self-correction",
    "Corrective RAG (CRAG) - Self-evaluating retrieval with fallback strategies",
    "Voice RAG Agent - Audio-based conversational retrieval",
    "MCP Agents - Browser, GitHub, and Notion integrations via MCP",
    "Agent Skills - Modular capabilities: code-reviewer, deep-research, python-expert, etc.",
    "Google ADK Framework - Model-agnostic agent development with tools and memory",
    "OpenAI Agents SDK - Swarm orchestration and multi-agent patterns",
    "LLM Optimization - Token optimization (TOON) and context compression (Headroom)",
    "Knowledge Graph RAG - Graph-based retrieval with citation tracking",
    "Autonomous Game Playing - Chess, Tic-Tac-Toe, and 3D game agents",
    "Mental Wellbeing Agent - Multi-agent therapeutic conversation system"
  ]
